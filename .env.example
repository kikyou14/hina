PORT=3000
HINA_DB_PATH=data/hina.sqlite
# HINA_ADMIN_PASSWORD=         # Initial admin password (first startup only). Omit to auto-generate.
# HINA_TRUSTED_PROXIES=        # Extra trusted reverse-proxy ranges beyond loopback. CSV of CIDRs or named groups: "private", "linklocal", "cgnat". Example: "private" for Docker / VPC deployments.
